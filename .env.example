# Copy to `.env` or `.env.local` (ignored by git) and adjust per environment.
# Vite only exposes variables prefixed with VITE_ to the browser.

# Backend API origin, without trailing slash (e.g. https://api.sendiaba.com)
VITE_API_URL=

# Local dev proxy target used by Vite for /api requests when VITE_API_URL is empty.
# Default fallback in config is http://localhost:3000.
API_PROXY_TARGET=http://localhost:3000
